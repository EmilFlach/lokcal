CREATE TABLE source_preference (
    preference_order INTEGER PRIMARY KEY CHECK (preference_order IN (1, 2)),
    source_id TEXT NOT NULL
);

getPreferences:
SELECT preference_order, source_id
FROM source_preference
ORDER BY preference_order;

setPreference:
INSERT OR REPLACE INTO source_preference(preference_order, source_id)
VALUES (?, ?);

clearAllPreferences:
DELETE FROM source_preference;
